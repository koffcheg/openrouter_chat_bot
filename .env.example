# Telegram
BOT_TOKEN=
BOT_USERNAME=
OWNER_USER_IDS=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=openrouter_chat_bot

# App runtime
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=true
TZ=Europe/Kiev

# Storage
DATABASE_URL=sqlite+aiosqlite:////app/data/bot.db
SQLITE_BUSY_TIMEOUT_MS=5000

# Safety / limits
DEFAULT_USER_COOLDOWN_SECONDS=20
DEFAULT_USER_DAILY_QUOTA=25
DEFAULT_CHAT_BURST_LIMIT=8
DEFAULT_CHAT_BURST_WINDOW_SECONDS=60
MAX_INPUT_CHARS=4000
MAX_CONTEXT_MESSAGES=8
MAX_CONTEXT_CHARS=12000
REQUEST_TIMEOUT_SECONDS=60

# Telegram delivery
TELEGRAM_MESSAGE_MAX_LEN=4096
TELEGRAM_PARSE_MODE=HTML

# Polling
POLLING_ALLOWED_UPDATES=message,edited_message
POLLING_DROP_PENDING_UPDATES=false

# Feature flags
ENABLE_ADMIN_MODEL_SELECTION=true
ENABLE_FALLBACK_ROUTING=true
ENABLE_USAGE_TRACKING=true
ENABLE_AUDIT_LOG=true

# Health / ops
HEALTHCHECK_FILE=/tmp/bot_healthy
STATUS_CACHE_TTL_SECONDS=10
